# Databricks Environment Configuration Template
# Copy this file to .env and replace placeholder values with your actual credentials

# Your Databricks workspace URL
DATABRICKS_HOST=https://your-workspace-url.azuredatabricks.net/

# Your Databricks Personal Access Token
# Instructions to get your token:
# 1. Go to your Databricks workspace
# 2. Click your user profile (top right) → Settings
# 3. Go to: Access Tokens tab → Generate New Token
# 4. Copy the token value here
DATABRICKS_TOKEN=your_databricks_token_here

# Note: The actual .env file with real credentials is ignored by git for security